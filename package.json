{
  "name": "eslint-config-valantic",
  "version": "18.0.0",
  "description": "The default ESLint config of valantic.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "release": "npm version patch -m 'Release %s' && git push --follow-tags",
    "release:minor": "npm version minor -m 'Release %s' && git push --follow-tags",
    "release:major": "npm version major -m 'Release %s' && git push --follow-tags",
    "test": "node test-setup.ts js && node test-setup.ts ts && node test-setup.ts vue",
    "test:ci": "node test-setup.ts js ci && node test-setup.ts ts ci && node test-setup.ts vue ci",
    "test:raw": "node test-setup.ts js raw && node test-setup.ts ts raw && node test-setup.ts vue raw",
    "snapshop:update": "UPDATE_SNAPSHOTS=true npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/valantic/eslint-config-valantic.git"
  },
  "author": "valantic",
  "license": "MIT",
  "keywords": [
    "eslint",
    "valantic",
    "eslint-config"
  ],
  "devDependencies": {
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^60.8.3",
    "eslint-plugin-unicorn": "^61.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "eslint": ">= 9",
    "eslint-plugin-import": "2.x"
  },
  "engines": {
    "node": ">= 18"
  }
}
